EOF

cat > app/optimizer.py << 'EOF'
from app.llm import ask_llm

def optimize_code(diff):
    return ask_llm(f"Optimize this code:\\n{diff}")
EOF

cat > app/agent.py << 'EOF'
from app.github_client import get_changed_files, comment_pr
from app.reviewer import review_code
from app.optimizer import optimize_code

def run_agent(pr_number: int):
    files = get_changed_files(pr_number)

    diff = ""
    for f in files:
        diff += f"\\nFile: {f['filename']}\\n{f.get('patch','')}\\n"

    review = review_code(diff)
    opt = optimize_code(diff)

    comment = f"## AI Review\\n\\n{review}\\n\\n---\\n\\n{opt}"
    comment_pr(pr_number, comment)
    return comment
EOF

cat > app/main.py << 'EOF'
from fastapi import FastAPI
from pydantic import BaseModel
from app.agent import run_agent

app = FastAPI()

class Req(BaseModel):
    pr_number: int

@app.post("/analyze")
def analyze(req: Req):
    return {"result": run_agent(req.pr_number)}
EOF

